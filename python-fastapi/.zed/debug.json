[
  {
    "label": "Debug Calc",
    "type": "python",
    "adapter": "Debugpy",
    "request": "launch",
    "cwd": "$ZED_WORKTREE_ROOT",
    "program": "$ZED_WORKTREE_ROOT/src/app.py",
    "python": "$ZED_WORKTREE_ROOT/.venv/bin/python3",
  },
  {
    "label": "Debug Tests",
    "type": "python",
    "adapter": "Debugpy",
    "request": "launch",
    "cwd": "$ZED_WORKTREE_ROOT",
    "program": "$ZED_WORKTREE_ROOT/.venv/bin/pytest",
    "python": "$ZED_WORKTREE_ROOT/.venv/bin/python3",
  },
  {
    "request": "attach",
    "adapter": "Debugpy",
    "label": "Remote Debug",
    "cwd": "$ZED_WORKTREE_ROOT",
    "host": "0.0.0.0",
    "port": 5678,
    "log": true,
    "pathMappings": [
      {
        "localRoot": "${ZED_WORKTREE_ROOT}",
        "remoteRoot": "${ZED_WORKTREE_ROOT}",
      },
    ],
  },
]
